{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rosclaw.io/schema/simforge/scenario_distribution.v1.json",
  "title": "ROSClaw Scenario Distribution v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "variables", "constraints"],
  "properties": {
    "schema_version": {"const": "rosclaw.simforge.scenario_distribution.v1"},
    "variables": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 64,
      "propertyNames": {"minLength": 1, "maxLength": 128},
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["distribution", "min", "max"],
            "properties": {
              "distribution": {"const": "uniform"},
              "min": {"type": "number"},
              "max": {"type": "number"}
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["values"],
            "properties": {
              "distribution": {"enum": ["choice", "list"]},
              "values": {
                "type": "array",
                "minItems": 1,
                "maxItems": 256,
                "items": {
                  "type": ["string", "number", "integer", "boolean", "null"]
                }
              }
            }
          }
        ]
      }
    },
    "constraints": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "oneOf": [
          {"type": "string", "minLength": 1, "maxLength": 128},
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {"type": "string", "minLength": 1, "maxLength": 128},
              "parameters": {
                "type": "object",
                "maxProperties": 32,
                "additionalProperties": {
                  "type": ["string", "number", "integer", "boolean", "null"]
                }
              }
            }
          }
        ]
      }
    },
    "max_sampling_attempts": {"type": "integer", "minimum": 1, "maximum": 10000}
  }
}
