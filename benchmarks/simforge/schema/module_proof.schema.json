{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rosclaw.io/schema/simforge/module_proof.v1.json",
  "title": "ROSClaw ModuleProof v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "module", "level", "invoked", "input_refs", "output_refs", "output_valid", "decision_impact", "counterfactual", "fault_injection", "replay_verified", "replay_ref"],
  "properties": {
    "schema_version": {"const": "rosclaw.module_proof.v1"},
    "module": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"},
    "level": {"enum": ["E0", "E1", "E2", "E3", "E4", "E5"]},
    "invoked": {"type": "boolean"},
    "input_refs": {"$ref": "#/$defs/refs"},
    "output_refs": {"$ref": "#/$defs/refs"},
    "output_valid": {"type": "boolean"},
    "decision_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed", "effects"],
      "properties": {
        "changed": {"type": "boolean"},
        "effects": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "counterfactual": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["control_run_id", "treatment_run_id", "same_seed", "same_scenario", "same_body_hash", "decision_changed", "outcome_changed", "metrics", "control_ref", "treatment_ref"],
          "properties": {
            "control_run_id": {"type": "string", "minLength": 1},
            "treatment_run_id": {"type": "string", "minLength": 1},
            "same_seed": {"const": true},
            "same_scenario": {"const": true},
            "same_body_hash": {"const": true},
            "decision_changed": {"type": "boolean"},
            "outcome_changed": {"type": "boolean"},
            "metrics": {"type": "array", "minItems": 1, "items": {"type": "object"}},
            "control_ref": {"$ref": "#/$defs/ref"},
            "treatment_ref": {"$ref": "#/$defs/ref"}
          }
        }
      ]
    },
    "fault_injection": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "evidence_ref"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"},
          "passed": {"type": "boolean"},
          "evidence_ref": {"$ref": "#/$defs/ref"}
        }
      }
    },
    "replay_verified": {"type": "boolean"},
    "replay_ref": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/ref"}]}
  },
  "$defs": {
    "ref": {"type": "string", "pattern": "^[a-z][a-z0-9+.-]*://[^ \t\r\n]+$"},
    "refs": {"type": "array", "items": {"$ref": "#/$defs/ref"}}
  }
}
