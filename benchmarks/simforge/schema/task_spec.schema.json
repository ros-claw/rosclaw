{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rosclaw.io/schema/simforge/task_spec.v1.json",
  "title": "ROSClaw SimForge Task Spec v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "suite_id", "body", "backends", "scenario_distribution", "success_spec", "safety_spec", "candidate_space", "evidence_requirements"],
  "properties": {
    "schema_version": {"const": "rosclaw.simforge.task.v1"},
    "task_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "suite_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body_id", "required_capabilities"],
      "properties": {
        "body_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "required_capabilities": {"type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
      }
    },
    "backends": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discovery", "evaluation", "differential"],
      "properties": {
        "discovery": {"$ref": "#/$defs/nonEmptyStrings"},
        "evaluation": {"$ref": "#/$defs/nonEmptyStrings"},
        "differential": {"$ref": "#/$defs/strings"}
      }
    },
    "scenario_distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {"ref": {"type": "string", "minLength": 1, "maxLength": 512}}
    },
    "success_spec": {"type": "object", "minProperties": 1, "maxProperties": 64},
    "safety_spec": {"type": "object", "minProperties": 1, "maxProperties": 64},
    "fault_model": {"type": "object", "maxProperties": 64},
    "candidate_space": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "allowed_paths"],
      "properties": {
        "type": {"const": "parameter_patch"},
        "allowed_paths": {"type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^/"}}
      }
    },
    "evidence_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["physics_executed", "strict_replay", "artifact_hashes", "minimum_seeds", "holdout_required"],
      "properties": {
        "physics_executed": {"const": true},
        "strict_replay": {"const": true},
        "artifact_hashes": {"const": true},
        "minimum_seeds": {"type": "integer", "minimum": 2, "maximum": 10000},
        "holdout_required": {"const": true}
      }
    }
  },
  "$defs": {
    "strings": {"type": "array", "maxItems": 128, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
    "nonEmptyStrings": {"allOf": [{"$ref": "#/$defs/strings"}, {"minItems": 1}]}
  }
}
