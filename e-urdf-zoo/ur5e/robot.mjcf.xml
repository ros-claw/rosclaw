<mujoco model="ur5e">
  <!-- UR5e MJCF — MuJoCo Simulation Layer -->
  <!-- Full detailed MJCF with meshes available in MuJoCo Menagerie -->
  <compiler angle="radian" meshdir="assets/" autolimits="true"/>

  <option timestep="0.002" integrator="implicitfast" solver="newton"
          iterations="50" ls_iterations="10">
    <flag warmstart="enable"/>
  </option>

  <worldbody>
    <body name="base" pos="0 0 0">
      <freejoint name="floating_base"/>  <!-- or fixed for table-mounted -->
      <body name="shoulder_link" pos="0 0 0.1625">
        <joint name="shoulder_pan_joint" type="hinge" axis="0 0 1"
               range="-6.283185 6.283185" damping="0.5"/>
        <body name="upper_arm_link" pos="0 0.138 0">
          <joint name="shoulder_lift_joint" type="hinge" axis="0 1 0"
                 range="-6.283185 6.283185" damping="0.5"/>
          <body name="forearm_link" pos="0 -0.131 0.425">
            <joint name="elbow_joint" type="hinge" axis="0 1 0"
                   range="-3.141593 3.141593" damping="0.5"/>
            <body name="wrist_1_link" pos="0 0 0.392">
              <joint name="wrist_1_joint" type="hinge" axis="0 1 0"
                     range="-6.283185 6.283185" damping="0.5"/>
              <body name="wrist_2_link" pos="0 0.127 0">
                <joint name="wrist_2_joint" type="hinge" axis="0 0 1"
                       range="-6.283185 6.283185" damping="0.5"/>
                <body name="wrist_3_link" pos="0 0 0">
                  <joint name="wrist_3_joint" type="hinge" axis="0 1 0"
                         range="-6.283185 6.283185" damping="0.5"/>
                  <site name="tool0" pos="0 0.1 0" size="0.01"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="shoulder_pan" joint="shoulder_pan_joint" gear="101" ctrllimited="true" ctrlrange="-150 150"/>
    <motor name="shoulder_lift" joint="shoulder_lift_joint" gear="101" ctrllimited="true" ctrlrange="-150 150"/>
    <motor name="elbow" joint="elbow_joint" gear="101" ctrllimited="true" ctrlrange="-150 150"/>
    <motor name="wrist_1" joint="wrist_1_joint" gear="50" ctrllimited="true" ctrlrange="-28 28"/>
    <motor name="wrist_2" joint="wrist_2_joint" gear="50" ctrllimited="true" ctrlrange="-28 28"/>
    <motor name="wrist_3" joint="wrist_3_joint" gear="50" ctrllimited="true" ctrlrange="-28 28"/>
  </actuator>

  <sensor>
    <force name="tcp_force" site="tool0"/>
    <torque name="tcp_torque" site="tool0"/>
  </sensor>
</mujoco>
